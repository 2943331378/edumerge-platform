# ===== EduMerge Docker 忽略文件 =====
# 确保 Docker build context 干净，加速构建

# IDE
.idea/
.vscode/
*.iml

# Git
.git/
.gitignore

# Node (前端)
frontend/node_modules/
frontend/.next/
frontend/.turbo/

# Maven (后端)
backend/target/

# 日志 & 临时文件
*.log
logs/
*.tmp

# 上传文件 (本地测试文件)
uploads/

# 评测脚本 (不需要在 Docker 镜像中)
scripts/

# OS
.DS_Store
Thumbs.db

# 文档
*.md
!CLAUDE.md
docs/
